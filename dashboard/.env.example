# Copy to dashboard/.env.local for local decision writes (updates ../tasks.json).
# On Vercel, set these in Project → Settings → Environment Variables.

# PIN Joseph enters once per browser session to lock in choices on the live dashboard
DECISIONS_SECRET=

# GitHub PAT (repo scope) — required on Vercel so choices persist to tasks.json on main
GITHUB_TOKEN=

# Optional overrides (defaults shown)
# GITHUB_REPO=Jamprey25/Legacy-
# GITHUB_BRANCH=main
