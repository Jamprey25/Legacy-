# Copy to .env.local and fill in. .env.local is gitignored.

# Neon Postgres connection string (from the Neon dashboard / Vercel integration).
# Use the POOLED connection string for serverless.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/legacy?sslmode=require"

# Secret for signing session JWTs (HS256). Generate: openssl rand -base64 32
SESSION_JWT_SECRET="change-me-32-bytes-min"

# OAuth audiences — reject tokens not minted for us.
APPLE_BUNDLE_ID="app.legacy.ios"
GOOGLE_CLIENT_ID="xxxxx.apps.googleusercontent.com"

# Email provider (OTP delivery). Stubbed to console in dev if unset.
RESEND_API_KEY=""
OTP_FROM_EMAIL="hello@legacy.app"

# Session lifetime (days)
SESSION_TTL_DAYS="30"
