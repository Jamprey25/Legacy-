{
  "name": "legacy-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env.local src/dev-server.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude 'test/integration/**'",
    "test:watch": "vitest --exclude 'test/integration/**'",
    "test:integration": "vitest run test/integration",
    "migrate": "tsx --env-file=.env.local scripts/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@neondatabase/serverless": "^0.10.4",
    "@vercel/blob": "^2.4.0",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "22.x"
  }
}
